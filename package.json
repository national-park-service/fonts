{
  "name": "@nps-fonts/monorepo",
  "version": "0.0.1",
  "private": true,
  "description": "Original open-source typefaces inspired by U.S. National Park Service signage — drawn from scratch",
  "license": "OFL-1.1",
  "homepage": "https://github.com/national-park-service/fonts",
  "repository": {
    "type": "git",
    "url": "https://github.com/national-park-service/fonts.git"
  },
  "bugs": {
    "url": "https://github.com/national-park-service/fonts/issues"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run scripts/build.ts --all",
    "build:fonts": "bun run scripts/build.ts --all",
    "build:family": "bun run scripts/build.ts --family",
    "web": "bun run scripts/web.ts",
    "web:dev": "bun run scripts/web.ts --serve",
    "dev": "bun run scripts/web.ts --serve",
    "cards": "bun run scripts/specimen-cards.ts",
    "review": "bun run scripts/review.ts",
    "check": "bun run scripts/check.ts",
    "lint": "bunx --bun pickier lint . --max-warnings 9999 || true",
    "typecheck": "bunx --bun tsc --noEmit",
    "clean": "rm -rf fonts/**/{otf,ttf,woff,woff2,variable}/*.* web/dist specimens/*.pdf packages/*/dist",
    "release": "bun run build && bun run web && bun run pack:all",
    "release:patch": "bun run scripts/release-version.ts patch",
    "release:minor": "bun run scripts/release-version.ts minor",
    "release:major": "bun run scripts/release-version.ts major",
    "pack:all": "bun run scripts/pack.ts",
    "test": "bun test",
    "verify": "bun run scripts/_verify-exact.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@stacksjs/ts-png": "https://registry.pantry.dev/@stacksjs/ts-png@15dffef",
    "@stacksjs/ts-svg": "https://registry.pantry.dev/@stacksjs/ts-svg@2940b3d",
    "ts-fonts": "https://registry.pantry.dev/ts-fonts@86f9b09"
  },
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=20"
  }
}
